# quantos configuration — copy to .env and adjust. Every value is OPTIONAL:
# the platform runs fully offline with defaults and NEVER requires a key (I6).
# No secret ever goes into code or git.

# Research defaults
QUANTOS_SYMBOL=BTC/USDT
QUANTOS_TIMEFRAME=1h
QUANTOS_BARS=400
QUANTOS_SEED=42

# Read-only market data (optional; synthetic fallback is always available)
QUANTOS_EXCHANGE_ID=binance

# Paper trading (I1: no real capital, ever)
QUANTOS_INITIAL_CASH=100000
QUANTOS_FEE_BPS=10
QUANTOS_SLIPPAGE_BPS=5
QUANTOS_MAX_POSITION_FRACTION=0.25

# Committee thresholds
QUANTOS_CONFIDENCE_THRESHOLD=0.35
QUANTOS_MIN_AGREEMENT=0.5

# Data Lake (M2): where curated data persists (optional; in-memory otherwise)
QUANTOS_LAKE_ROOT=.quantos-lake

# Optional infra (docker-compose; never required, I6). DSN only via env.
# QUANTOS_TIMESCALE_DSN=postgresql://user:pass@localhost:5432/quantos
# QUANTOS_DB_USER=quantos
# QUANTOS_DB_PASSWORD=change-me-locally
# QUANTOS_DB_NAME=quantos
